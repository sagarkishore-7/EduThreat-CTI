# EduThreat-CTI v2 worker Dockerfile
# Dedicated Postgres-backed worker/scheduler service for Railway
FROM python:3.13-slim

LABEL org.opencontainers.image.title="EduThreat-CTI v2 worker"

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    curl \
    wget \
    ca-certificates \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libatspi2.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libwayland-client0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxkbcommon0 \
    libxrandr2 \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

RUN playwright install chromium --with-deps
RUN patchright install chromium

COPY src/ ./src/
COPY scripts/ ./scripts/
COPY alembic/ ./alembic/
COPY pyproject.toml ./
COPY alembic.ini ./
COPY setup.py ./

RUN pip install --no-cache-dir .

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV EDU_CTI_V2_ENABLE_SCHEDULER=1
# auto = derive enrichment worker count from the container's memory limit minus
# the shared ML model floor, capped at the LLM provider rate limit. Pin to an
# integer (e.g. EDU_CTI_V2_WORKER_COUNT=4) to override. Tune the cap with
# EDU_CTI_V2_MAX_WORKERS and the floor with EDU_CTI_V2_MODEL_FLOOR_MB.
ENV EDU_CTI_V2_WORKER_COUNT=auto
ENV DISABLE_ML_FEATURES=true
# Concurrent CPU-bound inference serving: pin each article's NER/RAG (torch /
# sentence-transformers / GLiNER) inference to ONE core so multiple worker
# threads run their ML pre-pass on DIFFERENT cores in parallel, instead of every
# inference grabbing all cores (intra-op parallelism) and oversubscribing. This
# is what lets enrichment scale with vCPU while keeping the MITRE RAG/NER intact.
# Must be set before torch/numpy import → bake into the image env.
ENV OMP_NUM_THREADS=1
ENV MKL_NUM_THREADS=1
ENV OPENBLAS_NUM_THREADS=1
ENV TOKENIZERS_PARALLELISM=false
# The worker runs more threads than the API (enrichment + fetch + resolve +
# canonicalize + orchestrator + analytics), so give it a larger connection pool
# than the API's lean default so short worker transactions never starve. Stays
# well under Postgres max_connections for a single worker service.
ENV EDU_CTI_V2_DB_POOL_SIZE=16
ENV EDU_CTI_V2_DB_MAX_OVERFLOW=8

# --workers omitted ⇒ CLI default 0 ⇒ auto (the runtime reads
# EDU_CTI_V2_WORKER_COUNT directly via resolve_enrichment_worker_count).
CMD ["sh", "-c", "if [ \"${EDU_CTI_V2_ENABLE_SCHEDULER:-1}\" = \"0\" ]; then exec eduthreat-v2-runtime --no-scheduler; else exec eduthreat-v2-runtime; fi"]
