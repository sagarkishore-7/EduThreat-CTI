# EduThreat-CTI v2 local runtime overrides.
# Copy to .env.local. The helper script loads .env first, then .env.local, so
# secrets such as OLLAMA_API_KEY can stay in your existing .env.

# Persistent local Postgres container
EDU_CTI_LOCAL_POSTGRES_PORT=55433
EDU_CTI_LOCAL_POSTGRES_DB=eduthreat_cti_v2
EDU_CTI_LOCAL_POSTGRES_USER=eduthreat
EDU_CTI_LOCAL_POSTGRES_PASSWORD=eduthreat_local_password

# v2 database URLs used by API, worker, Alembic, and local CLIs
EDU_CTI_V2_DATABASE_URL=postgresql+psycopg://eduthreat:eduthreat_local_password@127.0.0.1:55433/eduthreat_cti_v2
ALEMBIC_DATABASE_URL=postgresql+psycopg://eduthreat:eduthreat_local_password@127.0.0.1:55433/eduthreat_cti_v2

# Local API/admin defaults
PORT=8000
EDUTHREAT_ADMIN_USERNAME=admin
EDUTHREAT_ADMIN_PASSWORD=admin123
EDUTHREAT_ADMIN_API_KEY=local-dev-admin-key

# Local worker shape. Tune this to compare with Railway.
EDU_CTI_V2_WORKER_COUNT=4
EDU_CTI_V2_FETCH_WORKER_COUNT=2
EDU_CTI_V2_RESOLVE_WORKER_COUNT=1
EDU_CTI_V2_CANONICALIZE_WORKER_COUNT=1
EDU_CTI_V2_ENABLE_SCHEDULER=0
EDU_CTI_V2_PREWARM_MODELS=0
EDU_CTI_V2_TASK_LEASE_SECONDS=300
LOG_LEVEL=INFO

# Cost-safe discovery/fetch defaults for local soak tests.
EDU_CTI_FETCH_TIER_PROFILE=scrapling_first
EDU_CTI_FETCH_ENABLE_NEWSPAPER=1
EDU_CTI_FETCH_ENABLE_LEGACY_TIERS=0
# Enables the Oxylabs article-fetch tier and, unless overridden below, the
# oxylabs_news source during collection.
EDU_CTI_OXYLABS_ENABLED=0
# Optional source-specific override for oxylabs_news collection.
# EDU_CTI_INCLUDE_OXYLABS_NEWS_SOURCE=0
EDU_CTI_ENABLE_OXYLABS_SERP=0
EDU_CTI_ENABLE_GOOGLE_NEWS_DISCOVERY=1
EDU_CTI_ENABLE_BING_NEWS_DISCOVERY=1
EDU_CTI_ENABLE_YAHOO_NEWS_DISCOVERY=0
EDU_CTI_NEWS_DISCOVERY_MAX_RESULTS=5
EDU_CTI_NEWS_DISCOVERY_DECODE_LIMIT=20
EDU_CTI_GOOGLE_NEWS_DECODE_TIMEOUT_SECONDS=4
EDU_CTI_ARTICLE_MIN_CONTENT_CHARS=500
EDU_CTI_FETCH_ENABLE_SCRAPLING_BROWSER=1
EDU_CTI_SCRAPLING_BROWSER_MODE=dynamic
EDU_CTI_SCRAPLING_BROWSER_MAX_CONCURRENCY=1
EDU_CTI_SCRAPLING_BROWSER_TRIGGER_REASONS=403,empty_content,soft_404

# Optional: switch to last-resort StealthyFetcher after archive.org fails.
# EDU_CTI_SCRAPLING_BROWSER_MODE=stealthy
# EDU_CTI_FETCH_ENABLE_SCRAPLING_STEALTH_LAST=1

# Optional: known-good proxy pool only. Do not auto-use public free proxies.
# EDU_CTI_SCRAPLING_PROXY_POOL=http://user:pass@host1:port,http://user:pass@host2:port
