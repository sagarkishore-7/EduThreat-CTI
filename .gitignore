# ============================================
# EduThreat-CTI .gitignore
# ============================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/
.env

# IDE
.idea/
.vscode/
.claude/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Data files (generated at runtime) - NEVER commit database files
*.db
*.db-shm
*.db-wal
data/*.db
data/*.db-shm
data/*.db-wal
data/eduthreat.db
data/eduthreat_sandbox.db
data/raw/
data/processed/
data/hf_cache/
data/benchmark_results*.json
data/mitre_*.json
data/mitre_*.npy
!data/.gitkeep

# Local-only runtime helpers
docker-compose.local.yml
docker-compose.override.yml

# Local benchmarking/research scratch outputs
docs/model_selection_benchmark.md
scripts/benchmark_models.py
scripts/run_full_benchmark.py

# Logs
logs/
*.log

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.bak
*.cache

# Jupyter
.ipynb_checkpoints/

# Build artifacts
*.manifest
*.spec

# Environment variables (keep .env.example)
.env
.env.*
!.env.example
!.env.*.example

# Paper directory (LaTeX source — managed separately on Overleaf)
paper/

# LLM-eval run artifacts (keep the harness + gold set, not per-run reports)
evals/reports/*.json
evals/reports/*.md
!evals/reports/.gitkeep
