{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.v2-worker",
    "watchPatterns": [
      "/Dockerfile.v2-worker",
      "/requirements.txt",
      "/pyproject.toml",
      "/setup.py",
      "/alembic.ini",
      "/alembic/**",
      "/src/edu_cti/core/**",
      "/src/edu_cti/sources/**",
      "/src/edu_cti/pipeline/**",
      "/src/edu_cti/analysis/**",
      "/src/edu_cti_v2/__init__.py",
      "/src/edu_cti_v2/__main__.py",
      "/src/edu_cti_v2/db/**",
      "/src/edu_cti_v2/models/**",
      "/src/edu_cti_v2/repositories/**",
      "/src/edu_cti_v2/services/**",
      "/src/edu_cti_v2/env.py",
      "/src/edu_cti_v2/normalization.py",
      "/src/edu_cti_v2/orchestrator_cli.py",
      "/src/edu_cti_v2/phase1_dual_write.py",
      "/src/edu_cti_v2/reset_db.py",
      "/src/edu_cti_v2/resource_limits.py",
      "/src/edu_cti_v2/runtime.py",
      "/src/edu_cti_v2/scheduler.py",
      "/src/edu_cti_v2/source_identity.py",
      "/src/edu_cti_v2/worker.py"
    ]
  }
}
