# ============================================
# EduThreat-CTI Environment Configuration
# Copy to .env for local dev
# Set these as Railway Environment Variables for production
# ============================================

# Ollama Cloud API (Required for Phase 2 LLM Enrichment)
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_HOST=https://ollama.com
OLLAMA_MODEL=deepseek-v3.1:671b-cloud

# Enrichment Workers (parallel LLM threads, 1-8)
# Higher = faster but more concurrent API calls
ENRICHMENT_WORKERS=2

# OTX AlienVault API Key (Optional, for IOC enrichment)
OTX_API_KEY=your_otx_api_key_here

# Database Configuration
# Railway: uses persistent volume at /app/data (set in Dockerfile)
# Local: defaults to ./data/eduthreat.db
# EDU_CTI_DATA_DIR=data
# EDU_CTI_DB_PATH=eduthreat.db

# Logging
LOG_LEVEL=INFO
# LOG_FILE=logs/pipeline.log

# Admin Authentication (set for production!)
# Generate hash: python -c "import hashlib; print(hashlib.sha256(b'your_password').hexdigest())"
# EDUTHREAT_ADMIN_PASSWORD_HASH=your_sha256_hash_here
# EDUTHREAT_ADMIN_API_KEY=your_api_key_here

# CORS (comma-separated origins)
# Production: set to your Vercel dashboard URL
# CORS_ALLOWED_ORIGINS=https://your-dashboard.vercel.app,http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Proxy (Optional - for geo-restricted scraping)
# PROXY_URL=http://127.0.0.1:9090

# Railway auto-injects PORT - no need to set it
